{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "lib": [
        "ES2020",
        "DOM",
        "WebWorker"
    ],
    "sourceMap": true,
    "outDir": "out",
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "src"
  },
  "include": [
     "src/**/*.ts"
  ],
  "exclude": [
     "node_modules"
  ]
}
